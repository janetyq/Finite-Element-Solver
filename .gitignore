__pycache__/
*.egg-info/
build/
dist/
_*
# ...but never ignore Python package markers (the _* rule matches __init__.py)
!**/__init__.py
temp*
todo.txt
test.py
profile*
ignore/
other/
*ignore*
*test*

# ...but do track the real pytest suite (the *test* rule above would ignore it)
!tests/
!tests/**
# keep caches out even under tests/ (re-ignore after the broad negation above)
tests/**/__pycache__/